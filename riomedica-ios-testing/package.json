{
  "name": "riomedica-ios-app",
  "version": "1.0.0",
  "description": "Riomedica Healthcare - Native iOS Mobile App powered by Capacitor",
  "scripts": {
    "sync": "cap sync",
    "open:ios": "cap open ios",
    "build:web": "cd ../client && npm run build",
    "build:ios": "npm run build:web && cap sync ios && cap open ios",
    "run:ios": "cap run ios"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "typescript": "^6.0.3"
  }
}

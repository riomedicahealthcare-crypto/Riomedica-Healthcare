{
  "appId": "com.riomedica.healthcare",
  "appName": "Riomedica Healthcare",
  "webDir": "../client/dist",
  "bundledWebRuntime": false,
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 3000,
      "launchAutoHide": true,
      "backgroundColor": "#0a0f1e",
      "showSpinner": false,
      "spinnerColor": "#10b981",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0f1e"
    },
    "Keyboard": {
      "resize": "body",
      "style": "DARK",
      "resizeOnFullScreen": true
    }
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#0a0f1e",
    "preferredContentMode": "mobile",
    "scrollEnabled": true
  },
  "server": {
    "allowNavigation": ["*"]
  }
}

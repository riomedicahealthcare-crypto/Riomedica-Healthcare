<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  iOS App Info.plist configuration for Riomedica Healthcare
  This file will be merged into the main Info.plist by Capacitor during sync.
  Copy the permission keys below into ios/App/App/Info.plist after running cap add ios
-->
<plist version="1.0">
<dict>

    <!-- App Display Name -->
    <key>CFBundleDisplayName</key>
    <string>Riomedica</string>

    <!-- Bundle Identifier - must match your App Store entry -->
    <key>CFBundleIdentifier</key>
    <string>com.riomedica.healthcare</string>

    <!-- App Version -->
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- Camera Permission (for document photo uploads) -->
    <key>NSCameraUsageDescription</key>
    <string>Riomedica uses your camera to capture document photos for registration and profile uploads.</string>

    <!-- Photo Library Permission -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Riomedica needs access to your photos to upload product images, drug licenses, and registration documents.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Riomedica needs access to save photos and order receipts to your photo library.</string>

    <!-- Microphone Permission (for AI Voice Assistant) -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Riomedica uses your microphone for the AI Voice Assistant (Riobot) to listen to your spoken product queries.</string>

    <!-- Speech Recognition -->
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Riomedica uses speech recognition to convert your voice queries into text for the AI assistant.</string>

    <!-- Network -->
    <key>NSAllowsArbitraryLoads</key>
    <true/>

    <!-- Face ID -->
    <key>NSFaceIDUsageDescription</key>
    <string>Riomedica uses Face ID for secure and fast authentication.</string>

    <!-- Orientation Support -->
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
    </array>

    <!-- Status Bar -->
    <key>UIStatusBarStyle</key>
    <string>UIStatusBarStyleLightContent</string>
    <key>UIViewControllerBasedStatusBarAppearance</key>
    <false/>

    <!-- Launch Screen -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>

</dict>
</plist>
